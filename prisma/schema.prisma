generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  BISPADO
  CONSELHEIRO
}

enum TipoAviso {
  AVISO
  NOVIDADE
  JORNAL
  EVENTO
}

enum ModoEntrevista {
  PRESENCIAL
  ONLINE
}

enum TipoAgendaSacramental {
  NORMA
  TESTEMUNHO
}

enum TipoMovimentoChamado {
  APOIO
  DESOBRIGACAO
}

enum OrganizacaoChamado {
  ELDERES
  SOCORRO
  RAPAZES
  MOCAS
  ESCOLA_DOMINICAL
  BISPADO
  OBRA_MISSIONARIA
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())

  disponibilidadesEntrevista DisponibilidadeEntrevista[]
  reservasEntrevista         ReservaEntrevista[]         @relation("EntrevistadorReservas")
}

model Pessoa {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
}

model Hino {
  id        String   @id @default(cuid())
  numero    Int      @unique
  nome      String
  createdAt DateTime @default(now())
}

model Chamado {
  id        String   @id @default(cuid())
  titulo    String   @unique
  createdAt DateTime @default(now())
}

model Agenda {
  id                        String   @id @default(cuid())
  data                      DateTime
  tipo                      TipoAgendaSacramental @default(NORMA)
  frequencia                Int?
  presididaPor              String?
  dirigidaPor               String?
  reconhecimentoAutoridades String?
  reconhecimentoVisitantes  String?
  anuncios                  String?
  regente                   String?
  organista                 String?
  hinoAbertura              String?
  primeiraOracao            String?
  hinoSacramental           String?
  primeiroOrador            String?
  segundoOrador             String?
  hinoEspecial              String?
  ultimoOrador              String?
  hinoEncerramento          String?
  oracaoEncerramento        String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  chamados AgendaChamado[]
}

model AgendaChamado {
  id           String @id @default(cuid())
  agendaId     String
  agenda       Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  tipo         TipoMovimentoChamado @default(APOIO)
  organizacao  OrganizacaoChamado?
  pessoa       String
  chamado      String
  ordem        Int    @default(0)
}

model Aviso {
  id          String    @id @default(cuid())
  titulo      String
  conteudo    String
  tipo        TipoAviso @default(AVISO)
  publicado   Boolean   @default(false)
  destaque    Boolean   @default(false)
  linkExterno String?
  publicadoEm DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ConteudoSemanal {
  id              String   @id @default(cuid())
  semanaInicio    DateTime @unique
  mensagemBispo   String?
  hinoSemana      String?
  versiculoTexto  String?
  versiculoRef    String?
  linkJornal      String?
  tituloJornal    String?
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EventoCalendario {
  id        String   @id @default(cuid())
  diaSemana Int
  titulo    String
  horario   String?
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([diaSemana, ordem])
}

model DisponibilidadeEntrevista {
  id         String   @id @default(cuid())
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  diaSemana  Int
  horaInicio String
  horaFim    String
  duracaoMin Int      @default(30)
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([usuarioId, diaSemana])
}

model ReservaEntrevista {
  id              String   @id @default(cuid())
  entrevistadorId String
  entrevistador   Usuario  @relation("EntrevistadorReservas", fields: [entrevistadorId], references: [id], onDelete: Cascade)
  inicio          DateTime
  fim             DateTime
  nomeMembro      String
  emailMembro     String?
  telefoneMembro  String?
  observacoes     String?
  modoEntrevista  ModoEntrevista @default(PRESENCIAL)
  createdAt       DateTime @default(now())

  @@unique([entrevistadorId, inicio])
  @@index([entrevistadorId, inicio])
}
